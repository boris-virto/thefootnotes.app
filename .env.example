# Скопируй этот файл в .env и заполни значения.
# Файл .env НЕ коммитим — он в .gitignore.

# Токен телеграм-бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Ключ Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ключ OpenAI (для транскрипции голосовых через Whisper) — https://platform.openai.com/
OPENAI_API_KEY=

# Кто имеет доступ к боту: твой telegram user id (число).
# Узнать свой id можно у бота @userinfobot. Несколько id — через запятую.
# Оставь пустым, чтобы разрешить всем (не рекомендуется).
ALLOWED_USER_IDS=

# Модель Claude для разбора смысла. Опционально.
# claude-opus-4-8 — умнее; claude-haiku-4-5 — дешевле и быстрее для простых заметок.
ANTHROPIC_MODEL=claude-opus-4-8

# Часовой пояс для времени регулярных напоминаний (IANA).
# Примеры: Europe/Belgrade, Europe/Moscow, Europe/Warsaw.
TIMEZONE=Europe/Belgrade

# Где хранить базу и файлы. По умолчанию — папка data/ рядом с кодом.
DATA_DIR=data

# Адрес базы данных. По умолчанию — SQLite-файл в DATA_DIR.
# Для переезда на PostgreSQL раскомментируй и подставь свои данные
# (и поставь драйвер: pip install "psycopg[binary]"):
# DATABASE_URL=postgresql+psycopg://thefootnotes:пароль@localhost:5432/thefootnotes
